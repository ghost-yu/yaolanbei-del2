[
  {
    "name": "\u5218\u4e00\u9ed8",
    "bio": "\u5973\uff0c\u4e2d\u56fd\u5730\u8d28\u5927\u5b66\uff08\u5317\u4eac\uff09\u7ecf\u6d4e\u7ba1\u7406\u5b66\u9662\u4f1a\u8ba1\u5b66\u4e13\u4e1a\u7684\u672c\u79d1\u751f\uff0c\u5171\u9752\u56e2\u5458\u3002\u76ee\u524d\u62c5\u4efb\u4e2d\u56fd\u5730\u8d28\u5927\u5b66\uff08\u5317\u4eac\uff09\u6821\u5b66\u751f\u4f1a\u6743\u76ca\u90e8\u6267\u884c\u8d1f\u8d23\u4eba\uff0c\u66fe\u53c2\u4e0e\u201c\u2018\u6c82\u2019\u8def\u5411\u515a\uff0c\u2018\u5eff\u2019\u7eed\u5149\u8363\u201d\u6691\u671f\u793e\u4f1a\u5b9e\u8df5\u56e2\u5e76\u83b7\u5f97\u201c\u9752\u5e74\u670d\u52a1\u56fd\u5bb6\u4f18\u79c0\u56e2\u961f\u201d\u5956\u9879\u3002\u5979\u6027\u683c\u7a33\u91cd\uff0c\u5f85\u4eba\u771f\u8bda\u53cb\u5584\uff0c\u6709\u8f83\u5f3a\u7684\u8d23\u4efb\u5fc3\u548c\u56e2\u961f\u610f\u8bc6\uff0c\u80fd\u5feb\u901f\u9002\u5e94\u65b0\u73af\u5883\u3002\u5b66\u4e60\u4e0a\uff0c\u5979\u6001\u5ea6\u7aef\u6b63\uff0c\u8ba4\u771f\u8e0f\u5b9e\uff0c\u8bfe\u5802\u8ba4\u771f\u542c\u8bb2\uff0c\u8bfe\u540e\u4e3b\u52a8\u62d3\u5c55\uff0c\u66fe\u83b7\u5c11\u6570\u6c11\u65cf\u4e09\u7b49\u5956\u5b66\u91d1\u3002\u5de5\u4f5c\u4e0e\u751f\u6d3b\u4e2d\uff0c\u5979\u79ef\u6781\u53c2\u4e0e\u73ed\u7ea7\u548c\u6821\u56ed\u6d3b\u52a8\uff0c\u5584\u4e8e\u6c9f\u901a\u534f\u4f5c\u3002\u5e73\u65f6\u7231\u597d\u65c5\u6e38\uff0c\u4e5f\u559c\u6b22\u7528\u955c\u5934\u8bb0\u5f55\u751f\u6d3b\uff0c\u4fdd\u6301\u79ef\u6781\u4e50\u89c2\u7684\u5fc3\u6001\u3002\u5979\u59cb\u7ec8\u4ee5\u4e25\u8c28\u81ea\u5f8b\u7684\u6001\u5ea6\u8981\u6c42\u81ea\u5df1\uff0c\u73cd\u60dc\u5927\u5b66\u65f6\u5149\uff0c\u613f\u610f\u5728\u5b66\u4e60\u548c\u5b9e\u8df5\u4e2d\u953b\u70bc\u81ea\u6211\u3001\u7a81\u7834\u81ea\u6211\uff0c\u52aa\u529b\u6210\u4e3a\u6709\u7406\u60f3\u3001\u6709\u672c\u9886\u3001\u6709\u62c5\u5f53\u7684\u65b0\u65f6\u4ee3\u5927\u5b66\u751f\u3002",
    "image_path": "E:\\xwechat_files\\wxid_9hgdfr7ula9429_d8af\\temp\\RWTemp\\2026-04\\8f3c72479183ef3e16d9d47668c46b79.jpg",
